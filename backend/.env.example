# ── API Service ──────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://stellar:stellar_dev_password@localhost:5432/stellar_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stellar / Soroban ────────────────────────────────────────
STELLAR_NETWORK=testnet
# Options: testnet | futurenet | mainnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract addresses (populated after deployment)
BOUNTY_CONTRACT_ID=
ESCROW_CONTRACT_ID=
FREELANCER_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRY_SECONDS=3600

# ── Logging ──────────────────────────────────────────────────
RUST_LOG=info,stellar_api=debug,stellar_indexer=debug

# ── Database Backup ──────────────────────────────────────────
# Cron schedule for automated pg_dump (default: daily at 02:00 UTC)
BACKUP_SCHEDULE=0 2 * * *
# S3 bucket and optional path prefix for backup files
BACKUP_S3_BUCKET=your-backup-bucket-name
BACKUP_S3_PREFIX=stellar/postgres
# Leave empty to use AWS S3; set for MinIO or other S3-compatible stores
BACKUP_S3_ENDPOINT=
# AWS credentials (use an IAM role in production instead of static keys)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
